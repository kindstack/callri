# All site-specific values for this PBX live in this one file. Copy this
# to `.env` (in this same directory) and fill in real values:
#
#     cp .env.example .env
#     vi .env
#
# Then bring the container up:
#
#     docker compose up -d --build
#
# To change a value later (no restart, active calls survive):
#
#     vi .env
#     docker exec asterisk reload-env
#
# `.env` is gitignored so your values never get committed.

#------------------------------------------------------------------------------
# Telnyx SIP trunk (Authentication & Routing tab in the Telnyx portal)
#------------------------------------------------------------------------------

TELNYX_USERNAME=REPLACE_WITH_TELNYX_SIP_USERNAME
TELNYX_PASSWORD=REPLACE_WITH_TELNYX_SIP_PASSWORD

# Your Telnyx-assigned DID in E.164 format (digits with leading +).
# Used as outbound caller-ID (Telnyx rejects non-DID values with
# 403 Forbidden on paid accounts) and as the inbound routing target.
TELNYX_DID=+15555551234

#------------------------------------------------------------------------------
# Public address (what Telnyx sees us as)
#------------------------------------------------------------------------------

# Use a DDNS hostname so Asterisk can re-resolve when your ISP rotates your
# IP -- set up DDNS separately on your router or NAS (Dynu, DuckDNS, No-IP,
# etc.). A raw IPv4 address works too, but you'll have to update this every
# time your ISP changes your IP.
PUBLIC_ADDRESS=pbx.dyn.example.com

#------------------------------------------------------------------------------
# Local SIP extension passwords (each softphone uses these to register)
#------------------------------------------------------------------------------

EXT_100_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_FOR_EXT_100
EXT_101_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_FOR_EXT_101

#------------------------------------------------------------------------------
# Inbound call routing
#------------------------------------------------------------------------------

# Which endpoint(s) to ring when a call comes in from Telnyx. Asterisk Dial()
# syntax -- '&' rings multiple in parallel, first to answer wins. Examples:
#   PJSIP/100                                     ring just ext 100
#   PJSIP/100&PJSIP/101                           ring both extensions (default)
#   PJSIP/100&PJSIP/+15125551234@telnyx-endpoint  also ring your mobile via Telnyx
# Unregistered endpoints are silently skipped, so the default safely rings
# whichever of 100/101 you've actually set up.
# NOTE: the value MUST be quoted -- '&' is the shell background operator and
# .env is parsed by shell. Use double quotes around the whole value.
INBOUND_DIAL="PJSIP/100&PJSIP/101"
